<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TestCodex — Sandbox</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600&family=Syne:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #09090b;
            --surface: #111113;
            --surface-2: #18181b;
            --surface-3: #1e1e22;
            --border: rgba(255,255,255,0.06);
            --border-accent: rgba(255,255,255,0.12);
            --text: #f4f4f5;
            --text-muted: #71717a;
            --text-dim: #3f3f46;
            --accent: #a3e635;
            --accent-dim: rgba(163, 230, 53, 0.12);
            --error: #f87171;
            --error-dim: rgba(248, 113, 113, 0.1);
            --mono: 'JetBrains Mono', monospace;
            --display: 'Syne', sans-serif;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: var(--mono);
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
            grid-template-rows: auto 1fr;
            gap: 0;
        }

        .topbar {
            grid-column: 1 / -1;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
            height: 56px;
            border-bottom: 1px solid var(--border);
            background: var(--surface);
        }

        .topbar-logo {
            font-family: var(--display);
            font-weight: 700;
            font-size: 16px;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .topbar-logo .dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: var(--accent);
            box-shadow: 0 0 8px var(--accent);
            animation: pulse 2s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }

        .topbar-meta {
            display: flex;
            align-items: center;
            gap: 20px;
            font-size: 11px;
            color: var(--text-muted);
            letter-spacing: 0.5px;
        }

        .topbar-meta span { display: flex; align-items: center; gap: 6px; }

        .status-dot {
            width: 5px; height: 5px; border-radius: 50%;
            background: var(--accent);
        }

        .panel {
            padding: 32px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .panel-left {
            border-right: 1px solid var(--border);
            background: var(--surface);
        }

        .panel-right {
            background: var(--bg);
        }

        .problem-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 24px;
        }

        .problem-title {
            font-family: var(--display);
            font-size: 22px;
            font-weight: 600;
            letter-spacing: -0.5px;
            color: var(--text);
            line-height: 1.2;
        }

        .badge {
            font-family: var(--mono);
            font-size: 10px;
            font-weight: 500;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            padding: 4px 10px;
            border-radius: 4px;
            border: 1px solid;
            flex-shrink: 0;
            margin-left: 16px;
            margin-top: 4px;
        }

        .badge-medium { color: #fbbf24; border-color: rgba(251,191,36,0.3); background: rgba(251,191,36,0.06); }
        .badge-easy   { color: var(--accent); border-color: rgba(163,230,53,0.3); background: rgba(163,230,53,0.06); }
        .badge-hard   { color: var(--error); border-color: rgba(248,113,113,0.3); background: rgba(248,113,113,0.06); }

        .problem-meta {
            display: flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 20px;
        }

        .problem-meta-label {
            font-size: 10px;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--text-dim);
        }

        .problem-meta-value {
            font-size: 11px;
            color: var(--text-muted);
            background: var(--surface-2);
            padding: 2px 8px;
            border-radius: 3px;
            border: 1px solid var(--border);
        }

        .problem-desc {
            font-size: 13px;
            line-height: 1.8;
            color: #a1a1aa;
            margin-bottom: 32px;
        }

        .section-label {
            font-size: 10px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--text-dim);
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .section-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .test-case {
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 14px 16px;
            margin-bottom: 8px;
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 6px 12px;
            font-size: 12px;
            transition: border-color 0.2s;
        }

        .test-case:hover { border-color: var(--border-accent); }

        .tc-label {
            color: var(--text-dim);
            font-size: 10px;
            letter-spacing: 0.5px;
            padding-top: 2px;
            white-space: nowrap;
        }

        .tc-value code {
            background: var(--surface-3);
            padding: 1px 6px;
            border-radius: 3px;
            font-size: 12px;
        }

        .editor-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 12px;
        }

        .lang-select-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .lang-select-wrapper::before {
            content: '⟨⟩';
            position: absolute;
            left: 12px;
            font-size: 11px;
            color: var(--text-muted);
            pointer-events: none;
            z-index: 1;
        }

        select#lenguaje {
            appearance: none;
            background: var(--surface-2);
            color: var(--text);
            border: 1px solid var(--border-accent);
            padding: 8px 32px 8px 34px;
            border-radius: 6px;
            font-family: var(--mono);
            font-size: 12px;
            cursor: pointer;
            outline: none;
            transition: border-color 0.2s, background 0.2s;
        }

        select#lenguaje:focus,
        select#lenguaje:hover {
            border-color: rgba(163,230,53,0.4);
            background: var(--surface-3);
        }

        .editor-lines {
            flex: 1;
            display: flex;
            min-height: 0;
        }

        .line-numbers {
            padding: 14px 12px 14px 0;
            font-size: 12px;
            line-height: 1.6;
            color: var(--text-dim);
            text-align: right;
            user-select: none;
            min-width: 36px;
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-right: none;
            border-radius: 8px 0 0 8px;
            overflow: hidden;
        }

        textarea#codigo {
            flex: 1;
            background: var(--surface-2);
            color: var(--text);
            border: 1px solid var(--border);
            border-left: none;
            border-radius: 0 8px 8px 0;
            padding: 14px 16px;
            font-family: var(--mono);
            font-size: 13px;
            line-height: 1.6;
            resize: none;
            outline: none;
            transition: border-color 0.2s;
            min-height: 0;
        }

        textarea#codigo:focus { border-color: rgba(163,230,53,0.3); }
        textarea#codigo::placeholder { color: var(--text-dim); }

        .btn-run {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            padding: 13px 24px;
            margin-top: 12px;
            background: var(--accent);
            color: #0a0a0a;
            border: none;
            border-radius: 8px;
            font-family: var(--display);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
            overflow: hidden;
        }

        .btn-run::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, transparent 0%, rgba(255,255,255,0.15) 50%, transparent 100%);
            transform: translateX(-100%);
            transition: transform 0.5s;
        }

        .btn-run:hover::before { transform: translateX(100%); }
        .btn-run:hover { background: #b9ff3a; transform: translateY(-1px); box-shadow: 0 4px 20px rgba(163,230,53,0.25); }
        .btn-run:active { transform: translateY(0); }
        .btn-run.loading { opacity: 0.7; cursor: wait; }

        .console-wrapper {
            margin-top: 16px;
            border: 1px solid var(--border);
            border-radius: 8px;
            overflow: hidden;
            flex-shrink: 0;
        }

        .console-topbar {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 14px;
            background: var(--surface-2);
            border-bottom: 1px solid var(--border);
        }

        .console-dot { width: 10px; height: 10px; border-radius: 50%; }

        .console-topbar-label {
            font-size: 11px;
            color: var(--text-muted);
            letter-spacing: 0.5px;
            margin-left: 4px;
        }

        #console-output {
            background: var(--bg);
            padding: 14px 16px;
            min-height: 100px;
            max-height: 240px;
            overflow-y: auto;
